{
  "name": "opengrid",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:portal": "npm -w portal run dev",
    "dev:forum": "npm -w forum run dev",
    "build:portal": "npm -w portal run build",
    "build:forum": "npm -w forum run build",
    "lint:portal": "npm -w portal run lint",
    "lint:forum": "npm -w forum run lint"
  }
}
